{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@0.6.0"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github@2025.3.15"]
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres@2025.1.1"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@2025.1.1"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search@2025.1.1"]
    },
    "custom-analytics": {
      "url": "https://analytics.internal.example.com/mcp/sse"
    },
    "datadog-monitoring": {
      "url": "https://mcp.datadog.example.com/v1/sse"
    },
    "jira-integration": {
      "url": "https://mcp-gateway.atlassian.example.com/jira/sse"
    },
    "linear-tracker": {
      "url": "https://mcp.linear.app/sse"
    },
    "code-search": {
      "command": "python",
      "args": ["mcp_servers/code_search_server.py", "--index-path", "./src"]
    },
    "doc-generator": {
      "command": "python",
      "args": ["mcp_servers/doc_generator_server.py", "--output", "./docs"]
    },
    "secret-scanner": {
      "command": "python",
      "args": ["mcp_servers/secret_scanner_server.py"]
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps@2025.1.1"]
    }
  }
}
